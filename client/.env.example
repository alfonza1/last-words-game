# Firebase web config for sign-in. Copy this file to `.env` (or `.env.local`)
# and fill in the values from your Firebase project. Restart `npm run dev` after.
#
# Where to find these: Firebase Console → your project → Project settings (gear)
# → "Your apps" → Web app (</>) → "SDK setup and configuration" → Config.
# These are PUBLIC client identifiers (safe to ship in a web app); security comes
# from Firebase Auth rules + backend token verification, not from hiding them.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: point the client at a non-default backend (defaults to /api proxy → :4100)
# VITE_API_BASE=

# --- Optional integrations (placeholders — leave unset until configured) ----
# Ads: set to "true" to turn on the rewarded-ad button + banner slots (see docs/DEPLOYMENT.md).
# VITE_ADS_ENABLED=false
# Banners: your AdSense publisher id + default ad-unit (slot) id. With ads enabled,
# setting the client id makes <AdBanner/> render a real AdSense unit (else a placeholder).
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# VITE_ADSENSE_SLOT=XXXXXXXXXX
# Coin packs: set to "true" once Stripe checkout is live on the server.
# VITE_STRIPE_ENABLED=false
# Error monitoring: set your Sentry DSN to enable client error reporting.
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=local
